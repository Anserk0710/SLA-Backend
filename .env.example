APP_NAME=SLA Ticketing API
API_V1_PREFIX=/api/v1
ENVIRONMENT=production
DEBUG=false

# Jika DATABASE_URL dikosongkan, backend akan fallback ke kombinasi MYSQL_* di bawah.
DATABASE_URL=
JWT_SECRET_KEY=replace-with-a-random-32-plus-character-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

CORS_ORIGINS=https://ptcahyaintanmedika.co.id
ALLOWED_HOSTS=ptcahyaintanmedika.co.id

APP_BASE_URL=https://ptcahyaintanmedika.co.id
PUBLIC_ROOT_DIR=/home/USERNAME/public_html
UPLOAD_DIR=/home/USERNAME/public_html/uploads
UPLOAD_URL_PREFIX=/uploads
STORAGE_BACKEND=local
BLOB_ACCESS=public
BLOB_READ_WRITE_TOKEN=

LOG_LEVEL=INFO
LOG_DIR=logs

PUBLIC_FORM_RATE_LIMIT=5
PUBLIC_FORM_RATE_WINDOW_SECONDS=300

MAX_IMAGE_UPLOAD_MB=5
MAX_VIDEO_UPLOAD_MB=25

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=ticketting

MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_DB=username_ticketing
MYSQL_USER=username_ticketing
MYSQL_PASSWORD=change-me

FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=change-me

GEOAPIFY_REVERSE_GEOCODE_URL=https://api.geoapify.com/v1/geocode/reverse
GEOAPIFY_API_KEY=
GEOAPIFY_LANG=id
